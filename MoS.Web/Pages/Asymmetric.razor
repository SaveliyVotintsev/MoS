@page "/asymmetric"

<MudGrid>
    <AsymmetricCrypt />

    <MudItem sm="6" xs="12">
        <MudTextField @bind-Value="PrimeP" FullWidth Label="Простое число P" Variant="Variant.Filled" />
    </MudItem>
    <MudItem sm="6" xs="12">
        <MudTextField @bind-Value="PrimeQ" FullWidth Label="Простое число Q" Variant="Variant.Filled" />
    </MudItem>

    <MudItem sm="6" xs="12">
        <MudStack>
            <MudSlider @bind-Value="KMin" Color="Color.Error" Max="100" Min="1">Минимальное k: @KMin.ToString()</MudSlider>
            <MudSlider @bind-Value="KMax" Color="Color.Info" Max="100" Min="1">Максимальное k: @KMax.ToString()</MudSlider>
        </MudStack>
    </MudItem>
    <MudItem xs="12" sm="6">
        <MudStack>
            <MudSlider @bind-Value="EMin" Color="Color.Error" Max="99" Min="3" Step="2">Минимальное e: @EMin.ToString()</MudSlider>
            <MudSlider @bind-Value="EMax" Color="Color.Info" Max="99" Min="3" Step="2">Максимальное e: @EMax.ToString()</MudSlider>
        </MudStack>
    </MudItem>
</MudGrid>

<MudButton Class="mt-4" Color="Color.Primary" OnClick="CalculateKeys" Variant="Variant.Filled">Нажми</MudButton>

<MudProgressLinear Buffer Class="my-2" Color="Color.Success" Value="@_progress" />

<MudTable Breakpoint="Breakpoint.None" FixedHeader Items="_results" SortLabel="Sort By" Striped>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<KeyResult, object>(x => x.Modulus)">Modulus (n)</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<KeyResult, object>(x => x.Phi)">Phi (φ)</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<KeyResult, object>(x => x.D)">d</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<KeyResult, object>(x => x.PrivateKey)">e</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<KeyResult, object>(x => x.K)">k</MudTableSortLabel>
        </MudTh>
        <MudTh>Открытый ключ</MudTh>
        <MudTh>Закрытый ключ</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Modulus (n)">@context.Modulus</MudTd>
        <MudTd DataLabel="Phi (φ)">@context.Phi</MudTd>
        <MudTd DataLabel="D">@context.D</MudTd>
        <MudTd DataLabel="e">@context.PublicKey</MudTd>
        <MudTd DataLabel="k">@context.K</MudTd>
        <MudTd DataLabel="Открытый ключ">@($"{{ {context.Modulus}, {context.PublicKey} }}")</MudTd>
        <MudTd DataLabel="Закрытый ключ">@($"{{ {context.Modulus}, {context.PrivateKey} }}")</MudTd>
    </RowTemplate>
</MudTable>

<MudText Color="Color.Error">@_errorMessage</MudText>
